    sr:hasSteps "Iris tipis tempe, labu siam dan kacang panjang--Blender bumbu yang harus dihaluskan--Tumis bumbu halus sampai harum, kemudian tuangkan air--Masukkan labu siam dan kacang panjang--Setelah air sedikit berkurang, masukkan potongan tempe--Masukkan santan kara yang sdh dicampur dengan air--Beri sedikit garam dan penyedap rasa--Tes rasa dan tunggu sampai sedikit mendidih--Lodeh TKL siap disajikan--" .

data:resep_Menu_dinner_trio_tumis_pokcoy_ayam_bawang_putih_bawang_merah a sr:MenuMasakan ;
    rdfs:label "Menu dinner trio tumis - pokcoy, ayam bawang putih, bawang merah"@id ;
    dcterms:identifier "REC_AYAM_004" ;
    dcterms:subject "ayam"@id ;
    sr:hasCategory data:kategori_ayam ;
    sr:hasIngredient data:bahan_2_potong_paha_ayam_potong_dadu,
        data:bahan_Ayam_bawang,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Garam_dan_kaldu_jamur,
        data:bahan_Gula_Aren,
        data:bahan_Kecap,
        data:bahan_Merica,
        data:bahan_air,
        data:bahan_cabe_hijau,
        data:bahan_cabe_merah,
        data:bahan_cabe_rawit,
        data:bahan_garam,
        data:bahan_jeruk_limo_peras,
        data:bahan_pokcoy ;
    sr:hasLoves 170 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4355199-menu-dinner-trio-tumis-pokcoy-ayam-bawang-putih-bawang-merah"^^xsd:anyURI ;
    sr:hasSteps "⭐ Tumis pokcoy: pokcoy cuci bersih, potong. Panaskan wajan, masukkan bawang putih lalu tumis sampai harum--Masukkan pokcoy, kecap asin, air, gula, garam. Aduk rata sekitar 30 detik. Angkat--⭐ Ayam bawang putih: campurkan semua dan marinasi di kulkas selama bbrp jam (saya 8 jam karena pagi bikin, pulang kantor masak)--Beri sedikit minyak, tumis hingga agak sedikit gosong, angkat--⭐ Tumis bawang merah: bawang merah diiris tipis, dan cabe iris miring--Beri minyak yg agak banyak (mgkn sekitar 4-5 sdm) lalu tumis bawang merah, cabe lalu aduk sampe harum. Masukkan gula, garam dan kaldu jamur. Aduk2 dan cicipi rasa. Jika sudah pas sisihkan--" .

data:resep_Mie_Ayam a sr:MenuMasakan ;
    rdfs:label "Mie Ayam"@id ;
    dcterms:identifier "REC_AYAM_003" ;
    dcterms:subject "ayam"@id ;
    sr:hasCategory data:kategori_ayam ;
    sr:hasIngredient data:bahan_Ayam,
        data:bahan_Bawang_Bombay,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Daun_Bawang,
        data:bahan_Garam_dan_penyedap_rasa,
        data:bahan_Kecap,
        data:bahan_Merica,
        data:bahan_Minyak_Wijen,
        data:bahan_embar_daun_jeruk,
        data:bahan_embar_daun_salam,
        data:bahan_jahe_haluskan,
        data:bahan_mie_telur,
        data:bahan_saos_tiram,
        data:bahan_serai ;
    sr:hasLoves 194 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4337966-mie-ayam"^^xsd:anyURI ;
    sr:hasSteps "Rebus mie telur sampai matang--Rebus ayam hingga empuk dengan sedikit garam kemudian potong kecil2--Tumis bawang bombay, bawang merah, bawang putih hingga harum--Tambahkan jahe giling, daun salam, daun jeruk dan serai.--Masukkan kecap manis, kecap asin, kecap inggris, minyak wijen dan saos tiram.--Masukan ayam yang telah di rebus aduk rata.--Masukkan garam, penyedap rasa, dan merica bubuk sesuai selera--Tambahkan sedikit air, masukan potongan daun bawang. Masak hingga empuk--Bahan kuah, siapkan air. Masukkan daun bawang, kaldu ayam, dan merica bubuk--Tata mie ayam. Letakkan mie, toping ayam dan siram dengan kuah.--" .

data:resep_NASI_KEBULI_MAGICOM_KitaBerbagi a sr:MenuMasakan ;
    rdfs:label "NASI KEBULI MAGICOM #KitaBerbagi"@id ;
    dcterms:identifier "REC_KAMBING_002" ;
    dcterms:subject "kambing"@id ;
    sr:hasCategory data:kategori_kambing ;
    sr:hasIngredient data:bahan_5_cm_Kayu_manis,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Bumbu_kari_instan,
        data:bahan_Bunga_lawang,
        data:bahan_Cengkeh_kering,
        data:bahan_Daging_Kambing,
        data:bahan_Garam,
        data:bahan_Kapulaga_ambil_bijinya,
        data:bahan_Ketumbar,
        data:bahan_Kunyit,
        data:bahan_Lada_bubuk,
        data:bahan_Margarin,
        data:bahan_Minyak_goreng,
        data:bahan_Secukupnya_Air,
        data:bahan_Secukupnya_Telur_dadar_emping_goreng_acar_bawang_goreng,
