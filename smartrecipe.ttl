    sr:hasLoves 169 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4349267-ayam-woku-manado"^^xsd:anyURI ;
    sr:hasSteps "Rebus Ayam di air Mendidih 7 Menit, buang kotorannya, bilas n Tiriskan.--Di Wajan, Tumis Bumbu halus dgn Minyak sampai Harum, masukkan daun jeruk, salam, pandan,sereh, tumis sampai Matang..--Masukkan Ayam, aduk Rata. Tambahkan Air dan Garam, gula n kaldu, tomat potong, aduk rata, koreksi Rasa.--Masak sampai Ayam Matang empuk n kuah menyusut. Matikan api, lalu masukkan daun kemangi, aduk sampai daun layu.--" .

data:resep_Bakso_Sapi_Homemade_bs_daging_frozen_bs_fresh a sr:MenuMasakan ;
    rdfs:label "Bakso Sapi Homemade (bs daging frozen bs fresh)"@id ;
    dcterms:identifier "REC_SAPI_004" ;
    dcterms:subject "sapi"@id ;
    sr:hasCategory data:kategori_sapi ;
    sr:hasIngredient data:bahan_2_sendok_munjung_maizena,
        data:bahan_3_sedok_munjung_kanji,
        data:bahan_Bawang_Putih,
        data:bahan_Daging_Sapi,
        data:bahan_Merica,
        data:bahan_es_batu_12_kg_an_air_es,
        data:bahan_sledry ;
    sr:hasLoves 269 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3396697-bakso-sapi-homemade-bs-daging-frozen-bs-fresh"^^xsd:anyURI ;
    sr:hasSteps "Pecahkan es batu campur dg air es.. (INI TIDAK DI PAKAI SEMUA YA) yg stengah biarkan ttp berukuran besar--Giling daging + sledry + garam + merica + penyedap + es batu plih yg ukuran kecil\"(sebesar es balok yg di cetakn itu)+ air es bberapa sendok.. Giling hingga halus.. (sya pakai chooper kecil jd aya choop 3x.. Stiap kliatan nggumpel tndax perlu di tambhkn 1 - 2 sendok air es biar g nyiksa chooperx) giling hingga bnr\" halus ya lbh enak pke food processor ( tapin jangan menambhakn terlalu banyak air nnti benyek. Ini hasil gilingan ttp halus padat bukn benyek --Klo dagingx udah alus masukan kanji + maizena uleni pakai tangan hingga bnr\" rata sya ulen agak lama biar kenyel, tp g perlu kalis jg sh ya ini bukn adonan roti .. klo mau blh colek dikit test rasa.. Klo udh pas asin gurihx lanjut pansakan air--Panaskan air pakai api sedang sj, tmbhkan garam tjuanx hsil rebusan bksox biar ga anyep.. klo udah kliatan mrintis\"airx.. clutut\"kan bakso pake tangan kanan.. Sekrup pake sendok langsung selupin di dalam air (sendokx hrs ikut nyelup jg biar baksox lepas sndri dr sendokx) lakukan hingga habis dan rebus hingga mengapung, Sisa es batu + air esx tadi jangan di buang.. Stelah bakso mengambang lngsung tiriskan n rendam air es ini.. Ini hg bs bkin kenyal..--Blh di tmbh 1 putih telur----------" .

data:resep_Bakso_Sapi_Pakai_Blender a sr:MenuMasakan ;
    rdfs:label "Bakso Sapi (Pakai Blender)"@id ;
    dcterms:identifier "REC_SAPI_001" ;
    dcterms:subject "sapi"@id ;
    sr:hasCategory data:kategori_sapi ;
    sr:hasIngredient data:bahan_Bawang_Putih,
        data:bahan_Daging_Sapi,
        data:bahan_Merica,
        data:bahan_baking_powder,
        data:bahan_es_batu,
        data:bahan_garam,
        data:bahan_putih_telur,
        data:bahan_tepung_tapioka ;
    sr:hasLoves 939 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3431604-bakso-sapi-pakai-blender"^^xsd:anyURI ;
    sr:hasSteps "Siapkan semua bahan, cincang daging sapi kecil2.--Masukkan daging cincang kedalam blender, tambahkan es batu (es nya di haluskan juga ya)--Proses sampai halus--Tanbahkan putih telur. Blender sampai rata. Tambahkan tepung tapioka, bawang putih, garam, merica dan baking powder. Proses lagi sampai tercampur rata--Siapkan baskom besar, masukkan adonan bakso, uleni, dan banting2 adonan sampai bener2 menyatu dan teksturnya lembut seperti pasta--Bulat2kan--Didihkan air, sampai benar2 mendidih, kecilkan api masukkan bulatan2 bakso. Jika sudah mengapung langsung angkate--Lalu taruh d air es--Tiriskan. Siap di olah, bisa dijadikan bakso kuah, bakso goreng, bakso bakar dll--Siap di olah, bisa dijadikan bakso kuah, bakso goreng, bakso bakar dll--" .

data:resep_Chilli_Tuna_Puff_Kilat_Super_Yummy a sr:MenuMasakan ;
    rdfs:label "Chilli Tuna Puff Kilat Super Yummy "@id ;
    dcterms:identifier "REC_IKAN_001" ;
    dcterms:subject "ikan"@id ;
    sr:hasCategory data:kategori_ikan ;
    sr:hasIngredient data:bahan_12_pack_Kulit_puff_instant_saya_merkEdo,
        data:bahan_1_Kaleng_Tuna_in_oil_pedas_saya_merk_Kingfisher,
        data:bahan_Bahan_Isian,
        data:bahan_Bawang_Putih,
        data:bahan_Telur_Rebus_potong2,
        data:bahan_secukupnya_Boncabechili_flakes,
        data:bahan_secukupnya_Garam,
        data:bahan_secukupnya_Gula,
        data:bahan_secukupnya_lada ;
    sr:hasLoves 516 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4463240-chilli-tuna-puff-kilat-super-yummy-%F0%9F%98%99"^^xsd:anyURI ;
    sr:hasSteps """Langkah 
1.Tumis chili tuna chunk dengan minyak bawang disusul jagung pipil,lalu masukkan gula+garam+merica/lada hitam sesuai selera.
2.Terakhir,taburi Chili Flakes/Boncabe dan Parsley cincang,aduk rata,sisihkan
3.Potong puff seperti di foto step2,isi dengan telur rebus+tuna,lalu lipat,pipihkan samping2nya menggunakan ujung garpu supaya tidak bocor
4.Oles kuning telur,semprot saus+parsley--Panggang dengan suhu kurleb 200 derajat sampai keemasan dan kokoh sekitar 18 menit atau sesuaikan oven sendiri
Enjoyyy----""" .

data:resep_Dimsum_siomay_udang_ayam a sr:MenuMasakan ;
    rdfs:label "Dimsum siomay udang ayam"@id ;
    dcterms:identifier "REC_UDANG_004" ;
    dcterms:subject "udang"@id ;
    sr:hasCategory data:kategori_udang ;
    sr:hasIngredient data:bahan_Bawang_Bombay,
        data:bahan_Daun_Bawang,
        data:bahan_Kecap,
        data:bahan_Kulit_pangsit_beli_jadi,
        data:bahan_Minyak_Wijen,
        data:bahan_Sop_Kool_dan_Wortel,
        data:bahan_ayam_giling,
        data:bahan_bangkuang_kecil_cincang,
        data:bahan_gula_pasir,
        data:bahan_sagu_tapioka_tani,
        data:bahan_saus_tiram,
        data:bahan_udang_kupas_cincang_kasar ;
    sr:hasLoves 109 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3934309-dimsum-siomay-udang-ayam"^^xsd:anyURI ;
    sr:hasSteps "Campur semua bahan dan bumbu jadi satu kecuali wortel yg dparut halus--Aduk rata, jika terlalu kerinf tambah kan air sedikir--Ambil kulit pangsit. Basahkan sekeliling nya menggunakan air dgn jari agar kulit pangsit elastis ketika d bentuk--Letakkan satu sendok adonan d tengah lalu d bentuk seperti d atas. Tambahkan parutan wortel d atasnya--Lalu kukus selama 20 s/d 30 menit. Beri jarak karna siomay akan mengembang.--Siomay siap d hidangkan. Bs jg d taro d kulkas dan d hangatkan sewaktu2--" .

data:resep_IKAN_ASIN_GABUS_KERING_CABE_GENDOT_BY_Dapoer_Linggar a sr:MenuMasakan ;
    rdfs:label "IKAN ASIN GABUS KERING CABE GENDOT... BY. Dapoer Linggar"@id ;
    dcterms:identifier "REC_IKAN_004" ;
    dcterms:subject "ikan"@id ;
    sr:hasCategory data:kategori_ikan ;
    sr:hasIngredient data:bahan_2_papan_pete,
        data:bahan_Bawang_Merah,
        data:bahan_Ga4am,
        data:bahan_Gula_Aren,
        data:bahan_Minyak_untuk_menumis,
        data:bahan_air,
        data:bahan_cabe_gendot_potong_kasar,
        data:bahan_cabe_hijau_iris_serong,
        data:bahan_embar_daun_salam_robek_2,
        data:bahan_gabus_kering_potong,
        data:bahan_optional_Penyedap,
        data:bahan_tomat_kecil_iris_kasar ;
    sr:hasLoves 196 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4067418-ikan-asin-gabus-kering-cabe-gendot-by-dapoer-linggar"^^xsd:anyURI ;
    sr:hasSteps "Rendam ikan asin dengan air panas beberapa saat agar garamnya berkurang lalu cuci bersih kemudian goreng kering--Tumis semua bumbu iris, pete, di tambah daun salam hingga harum lalu masukan ikan asin lalu aduk rata kemudian tambahkan air dan tutup sebentar--Menjelang di angkat masukan tomat iris lalu test rasa dahulu jika ku4ang asin bisa d tambahkan bumbu tambahan garam, gula pasir dan penyedap (Optional)--Jika semua rasa sudah oke angkat dan sajikan--NB : Test rasa dahulu seblum di tmbahkan bumbu tambahan agar makanan yang di sajikan tidak keasinan karena beberapa ikan asin memiliki rasa asin yang kuat... Jika tidak test rasa khawatir makanan keasinan...--Selamat mencoba... Jangn lupa yah reecook--" .

data:resep_Kalio_TaluaTelur_Tempe_pr_recookmasakanawalanT a sr:MenuMasakan ;
    rdfs:label "Kalio Talua/Telur & Tempe #pr_recookmasakanawalanT"@id ;
    dcterms:identifier "REC_TELUR_004" ;
    dcterms:subject "telur"@id ;
    sr:hasCategory data:kategori_telur ;
    sr:hasIngredient data:bahan_12_papan_tempe_potong_sesuai_selera,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Kunyit,
        data:bahan_Secukupnya_garam_gula_dan_kaldu_bubuk_jika_suka,
        data:bahan_Secukupnya_minyak_untuk_menumis,
        data:bahan_Secukupnya_santan_dari_1_butir_kelapa,
        data:bahan_Telur_Ayam,
        data:bahan_cabai_merah_besar,
        data:bahan_cabai_rawit_merah_utuh,
        data:bahan_embar_daun_jeruk,
        data:bahan_embar_daun_salam,
        data:bahan_jari_jahe,
        data:bahan_jari_laoslengkuas,
        data:bahan_serai_memarkan ;
    sr:hasLoves 160 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3919824-kalio-taluatelur-tempe-pr_recookmasakanawalant"^^xsd:anyURI ;
    sr:hasSteps "Tuang air santan kedalam panci, sisihkan. Tumis bumbu halus dan rempah daun menggunakan minyak sayur sampai harum.(resep asli gak ditumis dulu).--Kemudian tuang tumisan bumbu kedalam air santan yg didalam panci. Aduk rata. Nyalakan api. Masak sambil terus diaduk supaya santan tidak pecah. Beri garam, gula, dan kaldu bubuk (jika suka), aduk rata kembali.--Masukan telur rebus kupas dan potongan tempe masak terus sampai tempe matang. Terakhir masukan cabai rawit merah utuh. Tes rasa. Matikan api. Tutup supaya cabai layu. Siap disajikan.--" .

data:resep_Kalio_tenggiri a sr:MenuMasakan ;
