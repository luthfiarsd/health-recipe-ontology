        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Garam,
        data:bahan_Kunyit,
        data:bahan_Labu_Siam,
        data:bahan_Penyedap_rasa,
        data:bahan_Sedikit_lengkuas,
        data:bahan_cabe_merah,
        data:bahan_cabe_rawit,
        data:bahan_kacang_pangjang,
