data:resep_Tempe_Melet a sr:MenuMasakan ;
    rdfs:label "Tempe Melet"@id ;
    dcterms:identifier "REC_TEMPE_002" ;
    dcterms:subject "tempe"@id ;
    sr:hasCategory data:kategori_tempe ;
    sr:hasIngredient data:bahan_10_Cabe_Rawit_merahboleh_sesuaikan_kepedasan_lidah_masing2,
        data:bahan_1_Papan_Tempesaya_jadi_7_potong,
        data:bahan_3_Cabe_merah_keriting,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Daun_Bawang,
        data:bahan_Saos_Tomat,
        data:bahan_Tepung_Bumbu_serbagunakarna_ga_mau_ribet_bikin_tepung_sendiri,
        data:bahan_secukupnya_Trasi ;
    sr:hasLoves 280 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4354009-tempe-melet%F0%9F%91%85"^^xsd:anyURI ;
    sr:hasSteps "Potong tempe menjadi bbrp bagian,belah tengahnya jgn sampe putus ya.. Lebih baik potong tempe agak tebal,sisihkan--Tumis bahan isi,klo aku smua bahan aq blender dl br aku tumis smpe matang.. Terserah boleh tumis dl ato blender dl sesuai selera,beri sedikit garam--Lalu ambil tempe yg sudah dbelah td ambil isian masukkan ditengah2 tempe--Masukan tempe kedalam adonan tepung bumbu, Btw jgn terlalu encer dan kental ya adonannya..jgn lupa jg adonan tepung diberi daun bawang, lalu tempe siap digoreng hingga matang dan sajikan hangat2--" .

data:resep_Tempe_Orek_Basah a sr:MenuMasakan ;
    rdfs:label "Tempe Orek Basah"@id ;
    dcterms:identifier "REC_TEMPE_004" ;
    dcterms:subject "tempe"@id ;
    sr:hasCategory data:kategori_tempe ;
    sr:hasIngredient data:bahan_1_papan_tempe_uk_sedang_potong_dadu,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Kecap,
        data:bahan_Kemiri,
        data:bahan_Ketumbar,
        data:bahan_Saos_Tomat,
        data:bahan_Secukupnya_air_matang,
        data:bahan_Secukupnya_garam_gula_dan_kaldu_bubuk,
        data:bahan_Seruas_jempol_lengkuas_memarkan,
        data:bahan_cabai_merah_besar,
        data:bahan_embar_daun_salam,
        data:bahan_jeruk_limau_uk_besar_ambil_airnya ;
    sr:hasLoves 180 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4460395-tempe-orek-basah"^^xsd:anyURI ;
    sr:hasSteps "Goreng tempe yg sudah dipotong dadu sebentar sampai kecoklatan (jangan sampai kering ya)--Tumis bumbu halus, salam dan lengkuas menggunakan minyak sayur sampai harum dan matang. Lalu masukan air secukupnya. Aduk rata. Biarkan mendidih. Tuang kecap manis dan bumbu lainnya. Aduk rata kembali dan tes rasa.--Masukan tempe yg sudah digoreng tadi, aduk merata. Masak sampai bumbu meresap. Matikan kompor. Beri air perasan jeruk limau. Aduk rata. Siap disajikan.--Sajikan bersama nasi hangat.. sooo yummyy.--" .

data:resep_Tempe_isi_Sambel a sr:MenuMasakan ;
    rdfs:label "Tempe isi Sambel"@id ;
    dcterms:identifier "REC_TEMPE_003" ;
    dcterms:subject "tempe"@id ;
    sr:hasCategory data:kategori_tempe ;
    sr:hasIngredient data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Bongkrek_tempe_bungkil,
        data:bahan_Cabe_rawit,
        data:bahan_Daun_Kemangi,
        data:bahan_Garam_dan_penyedap,
        data:bahan_Minyak_goreng,
        data:bahan_Saos_Tomat,
        data:bahan_Tepung_bumbu_ayam_goreng_krispi_instan,
        data:bahan_sedikit_Air_matang ;
    sr:hasLoves 198 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4251330-tempe-isi-sambel"^^xsd:anyURI ;
    sr:hasSteps "Ulek kasar semua bahan sambel kecuali kemangi, tumis sebentar dengan sedikit minyak. Beri kemangi, Sisihkan--Potong tempe dan iris tidak putus bagian tengahnya, isi sambel tumis tadi--Siapkan tepung bumbu beri air, adonan kental ya--Panaskan minyak goreng lalu lumuri tempe isi dengan adonan basah tepung sampai tertutup merata--Goreng hingga matang--Sajikan------" .

data:resep_Tenggiri_kuah_asam_pedas a sr:MenuMasakan ;
    rdfs:label "Tenggiri kuah asam pedas"@id ;
    dcterms:identifier "REC_IKAN_002" ;
    dcterms:subject "ikan"@id ;
    sr:hasCategory data:kategori_ikan ;
    sr:hasIngredient data:bahan_3_cm_jahe_memarkan,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Belimbing,
        data:bahan_Daun_Bawang,
        data:bahan_Jeruk_Nipis,
        data:bahan_Kunyit,
        data:bahan_air,
        data:bahan_cabe_merah_keriting_iris_serong,
        data:bahan_cabe_rawit_iris_serong,
        data:bahan_cabe_rawit_utuh,
        data:bahan_ikan_tenggiri_potong_bulat,
        data:bahan_secukupnya_Garam_gula_lada_bubuk,
        data:bahan_serai_memarkan,
        data:bahan_tomat_hijau_potong_kasar ;
    sr:hasLoves 242 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4460709-tenggiri-kuah-asam-pedas"^^xsd:anyURI ;
    sr:hasSteps "Cuci bersih ikan, lumuri air jeruk nipis, diamkan 15 menit, cuci kembali sampai bersih, sisihkan.--Rebus air dalam panci hingga mendidih.--Tumis bumbu sampai wangi, masukkan cabe, daun jeruk, kunyit, serai & jahe, aduk2 sampai layu, tuang tumisan bumbu kedalam panci berisi air mendidih, bumbui garam & gula, masukkan ikan, masak sampai mendidih kembali.--Masukkan belimbing wuluh & cabe rawit utuh, masak sampai bumbu meresap, tes rasa, sebelum diangkat masukkan irisan tomat hijau, matikan api, taburi daun bawang sajikan. (Boleh taburi daun kemangi bila suka)--" .

data:resep_Udang_Asam_Pedas a sr:MenuMasakan ;
    rdfs:label "Udang Asam Pedas"@id ;
    dcterms:identifier "REC_UDANG_003" ;
    dcterms:subject "udang"@id ;
    sr:hasCategory data:kategori_udang ;
    sr:hasIngredient data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Belimbing,
        data:bahan_Jeruk_Nipis,
        data:bahan_Secukupnya_gula_garam_dan_kaldu_bubukjamur,
        data:bahan_Sejumput_lada,
        data:bahan_air_asam_jawa,
        data:bahan_cabe_hijau_besar_iris_serong,
        data:bahan_cabe_merah_keriting,
        data:bahan_cabe_rawit_merah_iris_serong,
        data:bahan_tomat_hijau_belah2,
        data:bahan_udang_agak_besar ;
    sr:hasLoves 118 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3838436-udang-asam-pedas"^^xsd:anyURI ;
    sr:hasSteps "Kupas udang, sisakan ekor dan belah punggung nya. Bersihkan dgn jeruk nipis dan garam. Bilas bersih dan tiriskan.--Panaskan minyak, tumis bumbu halus smp harum dan matang. Masuk udang adan aduk2 smp berubah warna.--Masukkan air, cabe iris, tomat dan belimbing sayur. Bumbui.--Setelah udang matang dan kuah mengental, masukkan asam jawa. Aduk2 bentaran dan siap disajikan...--" .

data:resep_Udang_Asam_manis_pedas_sederhana a sr:MenuMasakan ;
    rdfs:label "Udang Asam manis pedas sederhana"@id ;
    dcterms:identifier "REC_UDANG_005" ;
    dcterms:subject "udang"@id ;
    sr:hasCategory data:kategori_udang ;
    sr:hasIngredient data:bahan_12_bawang_bombai,
        data:bahan_2_biji_cabai_merah_besar,
        data:bahan_8_biji_cabai_rawit,
        data:bahan_Bawang_Putih,
        data:bahan_Garam,
        data:bahan_Gula_Aren,
        data:bahan_Kerupuk_Udang,
        data:bahan_Merica,
        data:bahan_Penyedap_rasa,
        data:bahan_Saori,
        data:bahan_Saus_tomat ;
    sr:hasLoves 108 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3836493-udang-asam-manis-pedas-sederhana"^^xsd:anyURI ;
    sr:hasSteps "Bersihkan kulit udang, cuci bersih.--Cincang bawang putih, potong cabai rawit dan cabai merah besar. Potong miring bawang bombay--Panaskan minyak dicapur margarin secukupnya--Tumis bawang bombay hingga harum--Lalu masukkan bawang putih cincang dan semua cabai--Tambahkan air sedikit atau sesuai selera agar meresap pada udang--Tambahkan saos tomat, saori, garam, gula, merica daan penyedap rasa--Masukkan udang yang telah bersih--Campurkan.. Dan tunggu 5 menit atau terasa bumbu sudah meresap--Lalu sajikan--" .

data:resep_Udang_Bakar a sr:MenuMasakan ;
    rdfs:label "Udang Bakar"@id ;
    dcterms:identifier "REC_UDANG_002" ;
    dcterms:subject "udang"@id ;
    sr:hasCategory data:kategori_udang ;
    sr:hasIngredient data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Jeruk_Nipis,
        data:bahan_Kecap,
        data:bahan_Secukupnya_garam_lada_bubuk_kaldu_bubuk_rasa_ayam,
        data:bahan_saos_sambal,
        data:bahan_tepung_tapioka,
        data:bahan_udang_ukuran_agak_besar ;
    sr:hasLoves 144 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4376433-udang-bakar"^^xsd:anyURI ;
    sr:hasSteps "Belah punggung udang, bersihkan tali hitamnya, cuci bersih--Kucuri perasan air jeruk nipis, aduk rata. Diamkan 10 menit. Cuci bersih--Beri 1 sdt garam. Remas2. Diamkan selama 15 menit. Tiriskan jika mengeluarkan air.--Lumuri udang dengan tepung tapioka tipis2. Goreng sebentar saja dalam minyak panas, hanya sampai berubah warna. Angkat. Tiriskan--Haluskan bawang merah dan bawang putih. Tumis di atas wajan sampai matang dan harum. Tambahkan kecap, saos sambal, garam, lada, dan kaldu bubuk. Aduk2 rata dengan api kecil. Koreksi rasa. Matikan api. Sisihkan--Lumuri udang dengan bumbu tumisan tadi hingga rata. Tusuk2 dengan lidi/tusukan sate. Diamkan minimal 15 menit.--Bakar di bara api atau teflon. Saya pakai fancy grill di atas kompor dengan api kecil. Tapi apapun alatnya, hasilnya tetap sama enaknya. Sajikan.--Note : fungsi menggoreng udang sebentar yg dilumuri tepung tapioka adalah supaya udang lebih empuk dan tidak keras setelah dibakar--" .

