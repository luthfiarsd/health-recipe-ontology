    sr:hasLoves 375 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3310336-sop-iga-sapi-enaaak-bangeet%F0%9F%91%8C%F0%9F%91%8D"^^xsd:anyURI ;
    sr:hasSteps "Didihkan secukupnya air, lalu masukan potongan iga sapi, rebus kurleb 5 menit, angkat, tiriskan, buang airnya ya karena perebusan pertama ini utk menghilangkan darah dan sebagian lemak supaya airnya nanti tidak terlalu berlemak. Lalu rebus kembali daging iga dan 2 liter air sampai lunak. (Saya pakai pressure cooker 35 menit). Sisihkan.--Tumis potongan bawang bombay menggunakan margarine sampai harum dan sisinya berkaramel. Masukan bumbu halus, tumis lagi beberapa saat, kemudian masukan kayumanis, cengkeh dan kapulaga, tumis sampai matang.--Masukan tumisan bumbu yg sudah matang kedalam rebusan iga sapi, aduk rata. Nyalakan kompor. (Boleh ditambahkan air jika air menyusut banyak saat proses perebusan). Lalu masukan kentang dan wortel, beri garam, gula dan kaldu bubuk, masak sampai wortel dan kentang matang. Tes rasa. Matikan kompor. Terakhir masukan potongan batang daun bawang, aduk rata kembali. Angkat.--Sajikan hangat bersama nasi dan pelengkapnya.--" .

data:resep_Sup_Baso_Ayam_Enoki_plus_Tahu a sr:MenuMasakan ;
    rdfs:label "Sup Baso Ayam Enoki plus Tahu "@id ;
    dcterms:identifier "REC_TAHU_004" ;
    dcterms:subject "tahu"@id ;
    sr:hasCategory data:kategori_tahu ;
    sr:hasIngredient data:bahan_300_daging_ayam_giling,
        data:bahan_4_cangkir_air,
        data:bahan_Bawang_Putih,
        data:bahan_Kecap,
        data:bahan_Minyak_Wijen,
        data:bahan_bawang_bombai,
        data:bahan_dashi_atau_kaldu_ayam,
        data:bahan_jamur_enoki,
        data:bahan_parutan_jahe,
        data:bahan_secukupnya_Garam_dan_lada,
        data:bahan_secukupnya_Sayuran_daun_kubis,
        data:bahan_tahu_potong_kotak2,
        data:bahan_tepung_maizena,
        data:bahan_wortel_iris_tipis ;
    sr:hasLoves 132 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4438476-sup-baso-ayam-enoki-plus-tahu-%F0%9F%8D%B2"^^xsd:anyURI ;
    sr:hasSteps "Siapkan bahan. Jamur Enoki dan bawang bombai iris kecil2. Tahu potong kotak2 besar--Campurkan daging, jamur enoki, bawang bombai dan seluruh bumbu bakso--Aduk dengan rata hingga mengental--Panaskan air hingga mendidih kemudian masukkan seluruh bumbu sup. masukkan bakso daging dengan sendok satu per satu. Kemudian masukkan sayur dan tahu. Koreksi rasa jika perlu--Sajikan dalam keadaan hangat bersama dengan nasi hangat--" .

data:resep_Tahu_Aci_Pedas_Manis_Bandung_RecookSenyRoss a sr:MenuMasakan ;
    rdfs:label "Tahu Aci Pedas Manis #Bandung_RecookSenyRoss"@id ;
    dcterms:identifier "REC_TAHU_003" ;
    dcterms:subject "tahu"@id ;
    sr:hasCategory data:kategori_tahu ;
    sr:hasIngredient data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Daun_Bawang,
        data:bahan_Ikan_telur_asin_mentah,
        data:bahan_Merica,
        data:bahan_cabe_rawit_merah,
        data:bahan_saus_cabai,
        data:bahan_saus_tomat,
        data:bahan_tahu_kuning,
        data:bahan_tepung_kanji ;
    sr:hasLoves 136 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4045334-tahu-aci-pedas-manis-bandung_recooksenyross"^^xsd:anyURI ;
    sr:hasSteps "Haluskan tahu dgn sendok/garpu lalu campur dgn bumbu halus (takaran 1) lalu masukan kocokan telur serta tepung kanji beri garam dan merica, aduk rata--Adonan yg dihasilkan tdk terlalu padat asalkan bisa dibulat2kan saja--Panaskan air hingga mendidih lalu masukan bulatan Adonan, masak kurleb 10 menit atau sampai adonan mengambang lalu angkat, tiriskan dan tunggu hingga dingin--Panaskan minyak goreng lalu masukan hasil rebusan adonan tadi, goreng hingga matang kecoklatan dan berkulit, angkat tiriskan--Tumis sisa bumbu halus (takaran 2) sampai harum lalu masukan bahan saos, aduk rata, koreksi rasa lalu masukan bulatan Adonan yg sdh digoreng, masukan daun bawang, aduk rata--Sajikan--" .

data:resep_Tahu_aci a sr:MenuMasakan ;
    rdfs:label "Tahu aci"@id ;
    dcterms:identifier "REC_TAHU_002" ;
    dcterms:subject "tahu"@id ;
    sr:hasCategory data:kategori_tahu ;
    sr:hasIngredient data:bahan_Bahan_sambal_cocolan,
        data:bahan_Bawang_Putih,
        data:bahan_Cabe_rawit_ulek_kasar,
        data:bahan_Campur_jd_satu,
        data:bahan_Daun_Bawang,
        data:bahan_Kecap,
        data:bahan_Secukupnya_air,
        data:bahan_Secukupnya_garam,
        data:bahan_Secukupnya_kaldu_bubuk,
        data:bahan_Tepung_Terigu,
        data:bahan_tahu_bandungtahu_kuning,
        data:bahan_tepung_tapioka ;
    sr:hasLoves 261 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4374296-tahu-aci"^^xsd:anyURI ;
    sr:hasSteps "Belah tahu membentuk segitiga lalu rendam dgn air garam,kerok dlm tahu lalu sisihkan tahunya,remas2 isian tahunya,sisihkan--Didihkan air di panci dgn bawang putih halus--Campur tepung dgn kaldu bubuk,garam daun bawang dan isi tahu yg sdh di remas2 td,tuangi air panas td sedikit2,aduk rata_--Panaskan minyak goreng yg byk,ambil tahu lalu beri isian,goreng dlm minyak panas hingga matang,jika tdk mau lgsg di goreng bs di rebus atau di kukus sebentar lalu simpan di kulkas --Klu mau buat stock di kulkas tahu aci bs di rebus sebentar atau di kukus dl yah bru di masukin kulkas,tp buat sy enak lgsg di goreng --" .

