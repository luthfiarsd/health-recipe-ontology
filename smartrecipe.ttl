data:resep_Ayam_Goreng_Bawang_Khas_Batam a sr:MenuMasakan ;
    rdfs:label "Ayam Goreng Bawang Khas Batam"@id ;
    dcterms:identifier "REC_AYAM_001" ;
    dcterms:subject "ayam"@id ;
    sr:hasCategory data:kategori_ayam ;
    sr:hasIngredient data:bahan_15_ruas_jari_jahe,
        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Ikan_telur_asin_mentah,
        data:bahan_Ketumbar,
        data:bahan_Kunyit,
        data:bahan_Merica,
        data:bahan_Secukupnya_garamkaldu_jamur,
        data:bahan_Secukupnya_minyak_goreng,
        data:bahan_ayam_bagian_apa_sajapotong_kecil,
        data:bahan_tepung_maizena ;
    sr:hasLoves 237 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4345660-ayam-goreng-bawang-khas-batam"^^xsd:anyURI ;
    sr:hasSteps "Cuci ayam hingga bersih kemudian tiriskan masukan bumbu halus,garam,kaldu jamur tepung maizena&telur aduk hingga tercampur rata--Diamkan kurang lebih 30 menit di kulkas supaya bumbu meresap--Panaskan minyak goreng kemudian goreng bawang putih hingga kuning&garing tiriskan--Kemudian goreng ayam hingga coklat keemasan&matang merata *saya pakai api kecil saja* untuk ayam nya goreng bertahap jangan sekali goreng semua nya angkat&tiriskan--Ayam goreng bawang siap di sajikan--" .

data:resep_Ayam_Goreng_Kecap a sr:MenuMasakan ;
    rdfs:label "Ayam Goreng Kecap"@id ;
    dcterms:identifier "REC_AYAM_002" ;
    dcterms:subject "ayam"@id ;
    sr:hasCategory data:kategori_ayam ;
    sr:hasIngredient data:bahan_2_cabe_merah_iris_serong,
        data:bahan_2_cm_jahe_memarkan,
        data:bahan_Bawang_Bombay,
        data:bahan_Bawang_Putih,
        data:bahan_Daun_Bawang,
        data:bahan_Gula_Aren,
        data:bahan_Merica,
        data:bahan_Minyak_utk_menggoreng,
        data:bahan_air_secukupnya,
        data:bahan_ayam_Potong_potong ;
    sr:hasLoves 218 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/4379354-ayam-goreng-kecap"^^xsd:anyURI ;
    sr:hasSteps "Lumuri ayam dg air jeruknipus dan garam, remas2, bilas bersih. Ungkep ayam dg garam dan merica. Boleh jg lgs goreng tp potong agak kecil.--Setelah diungkep, goreng ayam hngga sedikit kecokelatan, angkat.--Panaskan secukupnya minyak, tumis bawang putih dan jahe, masukkan bawang bombay, tumis hingga harum. Masukkan cabe merah iris, ayam goreng, bubuhi gula garam, merica dan kecap, tuangair. Masak hingga kuah mengental, sesaat sblm diangkat, masukkan daun bawang.--Angkat ayam dan sajikan--" .

