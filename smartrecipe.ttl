        data:bahan_Bawang_Merah,
        data:bahan_Bawang_Putih,
        data:bahan_Kecap,
        data:bahan_Saos_Tomat,
        data:bahan_Tauco_cap_DAS_cake,
        data:bahan_cabe_hijau,
        data:bahan_cabe_merah,
        data:bahan_petai ;
    sr:hasLoves 150 ;
    sr:hasSourceURL "https://cookpad.com/id/resep/3970221-tauco-telor-ceplok"^^xsd:anyURI ;
    sr:hasSteps "Goreng telur mata sapi--Bawang merah, bawang putih, Tomat, cabe di iris dan pete di bagi dua--Tumis bawang lalu masukkan pete dan cabe, kemudian masukkan tomat dan tauco--Masukkan sedikit air, kecap manis dan gula, masak hingga mendidih--Masukan telor celpok sebentar agar bumbunya meresap ke telur. Cek rasa yahh--Sajikannn...--" .

data:resep_Telur_ceplok_masak_tauco a sr:MenuMasakan ;
